# GitHub PAT with 'repo' scope — needed to checkout sushii-ansible (private) during CI
# https://github.com/settings/tokens
ANSIBLE_REPO_TOKEN=

# SSH private key for connecting to sushii servers (ansible.id_ed25519)
# Multiline — paste the full key including header/footer lines
# cat ../sushii-ansible/ansible.id_ed25519
ANSIBLE_SSH_PRIVATE_KEY=

# SSH known host fingerprints for all sushii deployment servers
# Generate with: ssh-keyscan 167.235.23.37 188.245.74.0 188.245.187.41
# (sushii-bot, apps, infra)
ANSIBLE_KNOWN_HOSTS=

# Ansible vault decryption password
# cat ../sushii-ansible/password
ANSIBLE_VAULT_PASSWORD=

# GitHub PAT with 'read:packages' scope — for docker pull auth on the deployment server
# Can reuse ANSIBLE_REPO_TOKEN if it has packages scope, or create a dedicated one
GHCR_TOKEN=
